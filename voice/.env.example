# Copy to voice/.env and fill in.
# .env is gitignored at the repo root, so secrets stay local.

# Streaming brain endpoint (the Edge Function deployed to Netlify).
# Falls back to the non-streaming /jarvis if you ever need to switch.
JARVIS_URL=https://elevate-sales-nav.netlify.app/jarvis-stream

# faster-whisper model. "small.en" = English-only, sub-second on CPU.
# Options: tiny.en | base.en | small.en | medium.en | large-v3
WHISPER_MODEL=small.en
# auto | cpu | cuda
WHISPER_DEVICE=auto
# int8 (fastest CPU), float16 (fast GPU), float32 (safest)
WHISPER_COMPUTE_TYPE=int8

# Silero VAD threshold (0.0–1.0). Lower = more sensitive (catches quieter speech).
VAD_THRESHOLD=0.5
# How many ms of silence before we treat the utterance as ended.
VAD_MIN_SILENCE_MS=350
# How many ms of speech before we trust it as an utterance (filters single coughs).
VAD_MIN_SPEECH_MS=200

# Piper voice file paths (set by setup_voice.py)
PIPER_VOICE_MODEL=voice/models/en_GB-cori-medium.onnx
PIPER_VOICE_CONFIG=voice/models/en_GB-cori-medium.onnx.json

# Audio device indices. Leave blank for system default.
# Run `python -m sounddevice` to list available devices.
INPUT_DEVICE=
OUTPUT_DEVICE=
